# secrets.sops.yaml — Polar local target secrets.
#
# This file is encrypted with SOPS using the keys in .sops.yaml.
# DO NOT commit the plaintext version of this file.
#
# To create your encrypted secrets file:
#   1. Copy this file to secrets.sops.yaml
#   2. Fill in the values below
#   3. Encrypt: SOPS_AGE_KEY_FILE=~/.ssh/id_github sops --encrypt --in-place secrets.sops.yaml
#
# To edit encrypted secrets:
#   SOPS_AGE_KEY_FILE=~/.ssh/id_github sops secrets.sops.yaml
#
# To decrypt for inspection:
#   SOPS_AGE_KEY_FILE=~/.ssh/id_github sops --decrypt secrets.sops.yaml

# =============================================================================
# Neo4j
# =============================================================================

# NEO4J_AUTH format: "neo4j/<password>"
# Used to create: neo4j-secret (polar-graph namespace)
neo4j_auth: "neo4j/changeme"

# Graph password — must match the password portion of neo4j_auth above.
# Used to create: polar-graph-pw (polar namespace)
graph_password: "changeme"

# =============================================================================
# OCI Registry
# =============================================================================

# Docker auth JSON for OCI registry access.
# Generate with: podman login <registry> && cat ~/.docker/config.json
# Used to create: oci-registry-auth (polar namespace)
docker_auth_json: ""

# =============================================================================
# GitLab
# =============================================================================

# GitLab personal access token with read_api scope.
# Used to create: gitlab-secret (polar namespace)
gitlab_token: ""

# GitLab instance endpoint.
gitlab_endpoint: "https://gitlab.com"

# GitLab username.
gitlab_user: ""

# =============================================================================
# Jira
# =============================================================================

# Jira API token.
# Used to create: jira-secret (polar namespace)
jira_token: ""

# =============================================================================
# Neo4j TLS
# =============================================================================

# Path to the neo4j CA certificate generated by gen-certs.nix.
# Used to create: neo4j-bolt-ca ConfigMap (polar namespace)
# This is a path, not a secret value — the file contents are read at apply time.
neo4j_ca_cert_path: "result-tls-certs/neo4j/ca_certificate.pem"
