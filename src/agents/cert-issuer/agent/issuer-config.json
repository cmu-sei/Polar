{
  "bind_addr": "0.0.0.0:8443",
  "ca": {
    "default_lifetime": {
      "nanos": 0,
      "secs": 1800
    },
    "provisioner": "cert-issuer",
    "provisioner_key_path": "/etc/cert-issuer/provisioner.key",
    "url": "https://step-ca.polar-system.svc.cluster.local:9000"
  },
  "issuer": {
    "allowed_algorithms": [
      "RS256",
      "ES256",
      "EdDSA"
    ],
    "audience": "polar-cert-issuer.dev",
    "instance_binding_claim": "kubernetes.io/pod/uid",
    "issuer": "https://kubernetes.default.svc",
    "jwks_cache_ttl_max": {
      "nanos": 0,
      "secs": 3600
    },
    "jwks_cache_ttl_min": {
      "nanos": 0,
      "secs": 30
    },
    "jwks_uri": "https://kubernetes.default.svc/openid/v1/jwks",
    "workload_identity_claim": "sub"
  }
}
