# =============================================================================
# Polar Development Environment
# =============================================================================
# Copy this file to my.env and fill in any values marked <required>.
# my.env is sourced by direnv on shell entry if it exists, overriding any
# defaults set in the flake devShell shellHook.
#
# DO NOT commit my.env. It contains secrets.
# =============================================================================


# =============================================================================
# CI / Build
# =============================================================================

# Short commit SHA used to tag container images. Automatically set by GitLab
# CI. For local development, defaults to the current HEAD.
export CI_COMMIT_SHORT_SHA=$(git rev-parse --short HEAD)


# =============================================================================
# Kubernetes / Deployment Namespaces
# =============================================================================

# The primary Polar namespace.
export NAMESPACE="polar"

# The namespace used for the Neo4j graph database.
export GRAPH_NAMESPACE="polar-graph"


# =============================================================================
# Neo4j / Graph Database
# =============================================================================

# Credentials for the Neo4j instance. Format: username/password.
# NEO4J_AUTH is derived from GRAPH_USER and GRAPH_PASSWORD.
export GRAPH_USER="neo4j"
export GRAPH_PASSWORD="somepassword"
export NEO4J_AUTH="$GRAPH_USER/$GRAPH_PASSWORD"

# Connection details for the graph database.
export GRAPH_ENDPOINT="bolt://127.0.0.1:7687"
export GRAPH_DB="neo4j"

# Optional: CA certificate for graph TLS verification.
# export GRAPH_CA_CERT=""


# =============================================================================
# Neo4j TLS (required if enableTls = True in values.dhall)
# =============================================================================

# PEM contents of the Neo4j server certificate, key, and CA cert.
# These are injected directly into Kubernetes secrets at render time.
export NEO4J_TLS_SERVER_CERT_CONTENT=""   # <required for TLS>
export NEO4J_TLS_SERVER_KEY_CONTENT=""    # <required for TLS>
export NEO4J_TLS_CA_CERT_CONTENT=""       # <required for TLS>


# =============================================================================
# GitLab
# =============================================================================

# URL of your GitLab instance.
export GITLAB_ENDPOINT="https://gitlab.example.com"

# Personal access token with at minimum: read_api, read_registry, read_repository.
export GITLAB_TOKEN=""        # <required>

# Username associated with GITLAB_TOKEN (used by Flux for OCI registry auth).
export GITLAB_USER=""         # <required>

# Separate token used by Flux to pull OCI artifacts from GitLab.
export FLUX_OCI_TOKEN=""      # <required for GitOps>


# =============================================================================
# OCI / Container Registry
# =============================================================================

# A docker config.json encoded as a base64 string, used as the image pull
# secret for the cluster. Generate with:
#   cat ~/.docker/config.json | base64 -w0
export DOCKER_AUTH_JSON=""    # <required>

# A docker config.json string (unencoded) used by the OCI resolver agent.
export DOCKER_CONFIG_STR=""   # <required>

# Base64-encoded OCI registry auth config used by the provenance resolver.
# Same source as DOCKER_AUTH_JSON in most cases.
export OCI_REGISTRY_AUTH=""   # <required>


# =============================================================================
# Cassini (Message Broker)
# =============================================================================

# Address Cassini binds to for its TCP broker interface.
export BIND_ADDR="127.0.0.1:8080"
export CASSINI_BIND_ADDR="$BIND_ADDR"

# Address broker clients use to connect to Cassini.
export BROKER_ADDR="$BIND_ADDR"

# TLS server name used when connecting to Cassini.
export CASSINI_SERVER_NAME="localhost"

# Token used to trigger a graceful Cassini shutdown.
export CASSINI_SHUTDOWN_TOKEN="HEYTHERE"

# PEM contents of the CA cert used to verify the Cassini server certificate.
export TLS_CA_CERT=""

# PEM contents of the Cassini server's certificate chain and private key.
export TLS_SERVER_CERT_CHAIN=""
export TLS_SERVER_KEY=""

# PEM contents of the client certificate and key for mTLS connections.
export TLS_CLIENT_CERT=""
export TLS_CLIENT_KEY=""

# Legacy client TLS vars (may be used by older agent configs).
export CLIENT_TLS_CRT=""
export CLIENT_PUB_KEY=""


# =============================================================================
# Cassini Test Controller
# =============================================================================

export CONTROLLER_BIND_ADDR="127.0.0.1:3030"
export CONTROLLER_ADDR="$CONTROLLER_BIND_ADDR"
export CONTROLLER_SERVER_NAME="localhost"
export HARNESS_SERVER_NAME="localhost"


# =============================================================================
# Polar Scheduler Agent
# =============================================================================

export POLAR_SCHEDULER_LOCAL_PATH="~/Documents/projects/polar-sched-test"
export POLAR_SCHEDULER_REMOTE_URL="https://github.com/daveman1010221/polar-schedules.git"
export POLAR_SCHEDULER_SYNC_INTERVAL="120"
export POLAR_SCHEDULER_GIT_USERNAME=""
export POLAR_SCHEDULER_GIT_PASSWORD=""


# =============================================================================
# Observability
# =============================================================================

export RUST_LOG="trace"
export JAEGER_ENABLE_TRACING="1"
export JAEGER_OTLP_ENDPOINT="http://localhost:4318/v1/traces"


# =============================================================================
# Kubernetes (local overrides, usually not needed)
# =============================================================================

# Uncomment if running agents outside of a cluster and need to fake the
# in-cluster Kubernetes API endpoint.
# export KUBERNETES_SERVICE_HOST="127.0.0.1"
# export KUBERNETES_SERVICE_PORT="45787"
